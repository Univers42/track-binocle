---
import { powerCards } from '../../data/site';
import PowerCard from '../ui/PowerCard.astro';
---

<section id="powers" class="section-shell powers-section" aria-labelledby="powers-title">
	<div class="section-heading">
		<p class="eyebrow">What is Prismatica?</p>
		<h2 id="powers-title">Six blocks. One engine.</h2>
		<p>Every block can be a note, a database view, a drawing, a dashboard cell or a custom app — all governed by the same reliable data layer.</p>
	</div>
	<div class="powers-grid">
		{powerCards.map((card) => <PowerCard card={card} />)}
	</div>
</section>
