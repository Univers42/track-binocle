---
import Layout from '../../layouts/Layout.astro';

const baasUrl = import.meta.env.PUBLIC_BAAS_URL ?? 'http://localhost:8000';
const anonKey = import.meta.env.PUBLIC_BAAS_ANON_KEY ?? '';
---

<Layout title="Reset your Prismatica password" description="Choose a new Prismatica password from a recovery email link.">
	<main class="auth-page" data-password-reset data-baas-url={baasUrl} data-anon-key={anonKey}>
		<section class="auth-card" aria-labelledby="reset-title">
			<p class="eyebrow">Password recovery</p>
			<h1 id="reset-title">Choose a new password</h1>
			<p class="auth-card__hint">Use at least 8 characters with one uppercase letter and one number.</p>
			<form class="auth-form" data-reset-form novalidate>
				<div class="field">
					<label for="new-password">New password</label>
					<input id="new-password" name="password" type="password" autocomplete="new-password" required minlength="8" />
				</div>
				<div class="field">
					<label for="confirm-password">Confirm new password</label>
					<input id="confirm-password" name="confirm_password" type="password" autocomplete="new-password" required minlength="8" />
				</div>
				<button class="portal-cta" type="submit">Update password →</button>
				<output class="portal-error" data-reset-status role="status" aria-live="polite" aria-atomic="true"></output>
			</form>
			<a class="text-link" href="/">Return home</a>
		</section>
	</main>
	<script is:inline>
		const root = document.querySelector('[data-password-reset]');
		const form = root?.querySelector('[data-reset-form]');
		const status = root?.querySelector('[data-reset-status]');
		const token = new URLSearchParams(window.location.search).get('token');
		const baasUrl = root?.dataset.baasUrl?.replace(/\/$/, '') ?? '';
		const anonKey = root?.dataset.anonKey ?? '';
		const strongEnough = (value) => value.length >= 8 && /[A-Z]/.test(value) && /\d/.test(value);
		const setStatus = (message, isError = false) => {
			if (!status) return;
			status.textContent = message;
			status.classList.toggle('is-error', isError);
		};
		if (!token) {
			setStatus('This reset link is missing its token.', true);
			form?.querySelector('button[type="submit"]')?.setAttribute('disabled', '');
		}
		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const password = form.elements.namedItem('password');
			const confirm = form.elements.namedItem('confirm_password');
			if (!(password instanceof HTMLInputElement) || !(confirm instanceof HTMLInputElement)) return;
			if (!strongEnough(password.value)) {
				setStatus('Password must be at least 8 characters and include one uppercase letter and one number.', true);
				password.focus();
				return;
			}
			if (password.value !== confirm.value) {
				setStatus('Both password fields must match.', true);
				confirm.focus();
				return;
			}
			if (!token || !baasUrl || !anonKey) {
				setStatus('Password reset is not configured for this environment.', true);
				return;
			}
			const button = form.querySelector('button[type="submit"]');
			button?.setAttribute('disabled', '');
			setStatus('Updating your password…');
			try {
				const response = await fetch(`${baasUrl}/auth/v1/user`, {
					method: 'POST',
					headers: {
						apikey: anonKey,
						Authorization: `Bearer ${token}`,
						Accept: 'application/json',
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({ password: password.value }),
				});
				if (!response.ok) throw new Error('reset_failed');
				setStatus('Your password was updated. Redirecting…');
				window.setTimeout(() => window.location.assign('/'), 3000);
			} catch {
				setStatus('Could not update the password. The link may be invalid or expired.', true);
				button?.removeAttribute('disabled');
			}
		});
	</script>
</Layout>
