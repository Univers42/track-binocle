{
  "name": "mini-baas",
  "version": "1.0.0",
  "private": true,
  "description": "Mini BaaS — NestJS monorepo",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "build:all": "nest build adapter-registry && nest build mongo-api && nest build query-router && nest build storage-router && nest build email-service && nest build permission-engine && nest build schema-service && nest build analytics-service && nest build gdpr-service && nest build newsletter-service && nest build ai-service && nest build log-service && nest build session-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start:adapter-registry": "nest start adapter-registry",
    "start:mongo-api": "nest start mongo-api",
    "start:query-router": "nest start query-router",
    "start:storage-router": "nest start storage-router",
    "start:email-service": "nest start email-service",
    "start:permission-engine": "nest start permission-engine",
    "start:schema-service": "nest start schema-service",
    "start:dev:adapter-registry": "nest start adapter-registry --watch",
    "start:dev:mongo-api": "nest start mongo-api --watch",
    "start:dev:query-router": "nest start query-router --watch",
    "start:dev:storage-router": "nest start storage-router --watch",
    "start:dev:email-service": "nest start email-service --watch",
    "start:dev:permission-engine": "nest start permission-engine --watch",
    "start:dev:schema-service": "nest start schema-service --watch",
    "start:analytics-service": "nest start analytics-service",
    "start:gdpr-service": "nest start gdpr-service",
    "start:newsletter-service": "nest start newsletter-service",
    "start:ai-service": "nest start ai-service",
    "start:log-service": "nest start log-service",
    "start:session-service": "nest start session-service",
    "start:dev:analytics-service": "nest start analytics-service --watch",
    "start:dev:gdpr-service": "nest start gdpr-service --watch",
    "start:dev:newsletter-service": "nest start newsletter-service --watch",
    "start:dev:ai-service": "nest start ai-service --watch",
    "start:dev:log-service": "nest start log-service --watch",
    "start:dev:session-service": "nest start session-service --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./jest-e2e.json",
    "observatory": "ts-node -r tsconfig-paths/register tools/observatory.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@willsoto/nestjs-prometheus": "^6.0.1",
    "axios": "^1.7.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mongodb": "^6.15.0",
    "nestjs-pino": "^4.2.0",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@mini-baas/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@mini-baas/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@mini-baas/health(|/.*)$": "<rootDir>/libs/health/src/$1"
    }
  }
}
