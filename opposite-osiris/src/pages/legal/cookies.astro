---
import Layout from '../../layouts/Layout.astro';
import { CONSENT_STORAGE_KEY, CSRF_STORAGE_KEY, NEWSLETTER_INTENT_KEY, POLICY_LAST_UPDATED, POLICY_VERSION } from '../../data/legal';
---

<Layout title="Cookie Policy — Prismatica" description="Prismatica cookie and local storage policy.">
	<main class="legal-page section-shell">
		<a href="/" class="legal-page__back">← Back to Prismatica</a>
		<h1>Cookie Policy</h1>
		<p><strong>Version:</strong> {POLICY_VERSION} · <strong>Last updated:</strong> {POLICY_LAST_UPDATED}</p>
		<p>Prismatica currently uses local storage rather than browser cookies. Optional analytics, marketing or newsletter tracking must not be loaded unless consent is granted.</p>

		<table class="legal-table">
			<thead>
				<tr><th>Name</th><th>Type</th><th>Purpose</th><th>Lifetime</th><th>Consent required?</th></tr>
			</thead>
			<tbody>
				<tr><td>prismatica-theme</td><td>localStorage</td><td>Stores light, dark or night interface preference.</td><td>Until cleared or changed.</td><td>No, strictly necessary preference.</td></tr>
				<tr><td>prismatica-motion-paused</td><td>localStorage</td><td>Stores reduced motion preference for accessibility.</td><td>Until cleared or changed.</td><td>No, accessibility preference.</td></tr>
				<tr><td>{CONSENT_STORAGE_KEY}</td><td>localStorage</td><td>Stores consent choices, timestamp and policy version.</td><td>13 months or until changed.</td><td>No for storing proof of choice; optional categories require consent.</td></tr>
				<tr><td>{NEWSLETTER_INTENT_KEY}</td><td>localStorage</td><td>Stores unauthenticated newsletter opt-in intent until login sync.</td><td>Until sync or manual clearing.</td><td>Yes, newsletter consent.</td></tr>
				<tr><td>{CSRF_STORAGE_KEY}</td><td>localStorage</td><td>Stores a CSRF nonce for the public data-rights form.</td><td>Session-length operational use.</td><td>No, security necessity.</td></tr>
			</tbody>
		</table>

		<button class="button button--ghost" type="button" data-manage-cookies>Manage cookie preferences</button>
	</main>
</Layout>
