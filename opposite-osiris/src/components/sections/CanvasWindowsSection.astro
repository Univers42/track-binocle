					<text x="386" y="366" font-family="var(--system-font-mono)" font-size="10" fill="var(--brand-canvas-text-dim)" stroke="none">value</text>
					<text x="446" y="366" font-family="var(--system-font-mono)" font-size="10" fill="var(--brand-canvas-text-dim)" stroke="none">ts</text>
					<line x1="250" y1="394" x2="490" y2="394" stroke-dasharray="2 4" opacity="0.5" /><rect x="266" y="380" width="18" height="8" rx="2" /><rect x="306" y="380" width="60" height="8" rx="2" /><rect x="386" y="380" width="24" height="8" rx="2" stroke="var(--brand-palette-secondary)" /><rect x="446" y="380" width="34" height="8" rx="2" />
					<line x1="250" y1="416" x2="490" y2="416" stroke-dasharray="2 4" opacity="0.5" /><rect x="266" y="402" width="18" height="8" rx="2" /><rect x="306" y="402" width="60" height="8" rx="2" /><rect x="386" y="402" width="34" height="8" rx="2" stroke="var(--brand-palette-secondary)" /><rect x="446" y="402" width="34" height="8" rx="2" />
					<line x1="250" y1="438" x2="490" y2="438" stroke-dasharray="2 4" opacity="0.5" /><rect x="266" y="424" width="18" height="8" rx="2" /><rect x="306" y="424" width="60" height="8" rx="2" /><rect x="386" y="424" width="47" height="8" rx="2" stroke="var(--brand-palette-secondary)" /><rect x="446" y="424" width="34" height="8" rx="2" />
					<line x1="250" y1="460" x2="490" y2="460" stroke-dasharray="2 4" opacity="0.5" /><rect x="266" y="446" width="18" height="8" rx="2" /><rect x="306" y="446" width="60" height="8" rx="2" /><rect x="386" y="446" width="38" height="8" rx="2" stroke="var(--brand-palette-secondary)" /><rect x="446" y="446" width="34" height="8" rx="2" />
					<line x1="250" y1="482" x2="490" y2="482" stroke-dasharray="2 4" opacity="0.5" /><rect x="266" y="468" width="18" height="8" rx="2" /><rect x="306" y="468" width="60" height="8" rx="2" /><rect x="386" y="468" width="57" height="8" rx="2" stroke="var(--brand-palette-secondary)" /><rect x="446" y="468" width="34" height="8" rx="2" />
					<line x1="250" y1="504" x2="490" y2="504" stroke-dasharray="2 4" opacity="0.5" /><rect x="266" y="490" width="18" height="8" rx="2" /><rect x="306" y="490" width="60" height="8" rx="2" /><rect x="386" y="490" width="31" height="8" rx="2" stroke="var(--brand-palette-secondary)" /><rect x="446" y="490" width="34" height="8" rx="2" />
