# -----------------------------------------------------------------------------
# opposite-osiris website and auth gateway
# Managed by apps/baas/scripts/vault-env.mjs.
# Copy to the matching .env file only for local development; Vault is the source of truth after seeding.
# -----------------------------------------------------------------------------

# REQUIRED: Required. The service will not boot, authenticate, or bridge correctly without these keys.
# Required. Runtime configuration key for this service. If omitted: startup, auth, or bridge flow can fail.
ASTRO_DEV_HOST=0.0.0.0

# Required. Local port for Docker or development tooling. If omitted: startup, auth, or bridge flow can fail.
ASTRO_DEV_PORT=4322

# Required. Browser-exposed configuration. Never put private secrets in this key. If omitted: startup, auth, or bridge flow can fail.
PUBLIC_AUTH_GATEWAY_URL=/api/auth

# Required. Browser-exposed configuration. Never put private secrets in this key. If omitted: startup, auth, or bridge flow can fail.
PUBLIC_BAAS_ANON_KEY=replace-with-public-baas-anon-key

# Required. Browser-exposed configuration. Never put private secrets in this key. If omitted: startup, auth, or bridge flow can fail.
PUBLIC_BAAS_URL=/api

# Required. Browser-exposed configuration. Never put private secrets in this key. If omitted: startup, auth, or bridge flow can fail.
PUBLIC_OSIONOS_APP_URL=http://localhost:3001

# Required. Browser-exposed configuration. Never put private secrets in this key. If omitted: startup, auth, or bridge flow can fail.
PUBLIC_SITE_URL=http://localhost:4322

# RECOMMENDED: Recommended. Defaults keep local Docker usable, but set these to make routing, email, and integrations explicit.
# Recommended. Runtime configuration key for this service. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Recommended. GoTrue authentication service configuration. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GOTRUE_MAILER_AUTOCONFIRM=true

# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
PUBLIC_AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
PUBLIC_PORTAL_URL=http://localhost:4322

# Recommended. Cloudflare Turnstile anti-abuse setting. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
TURNSTILE_BYPASS_LOCAL=true

# OPTIONAL: Optional. Leave empty to disable the integration and gain a smaller local attack surface.
# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
ASTRO_DEV_HTTPS=false

# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
ASTRO_DEV_HTTPS_CERT=

# Optional. Secret or token used for local authentication. If omitted: the related integration is disabled, reducing local secret sprawl.
ASTRO_DEV_HTTPS_KEY=

# Optional. Browser-exposed configuration. Never put private secrets in this key. If omitted: the related integration is disabled, reducing local secret sprawl.
PUBLIC_TURNSTILE_SITE_KEY=

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_ENCRYPTION=none

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_FROM_ADDRESS=noreply@mini-baas.local

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_FROM_NAME=opposite-osiris

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_HOST=mailpit

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_PASSWORD=

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_PORT=1025

# Optional. SMTP setting used when local email delivery is enabled. If omitted: the related integration is disabled, reducing local secret sprawl.
SMTP_USERNAME=

# Optional. Cloudflare Turnstile anti-abuse setting. If omitted: the related integration is disabled, reducing local secret sprawl.
TURNSTILE_SECRET_KEY=

# LEGACY: Legacy or compatibility. Keep only while older scripts or clients still reference these names.
# Compatibility. Browser-exposed configuration. Never put private secrets in this key. If omitted: modern code should keep working once no legacy references remain.
NEXT_PUBLIC_BAAS_ANON_KEY=replace-with-next-public-baas-anon-key

# Compatibility. Browser-exposed configuration. Never put private secrets in this key. If omitted: modern code should keep working once no legacy references remain.
NEXT_PUBLIC_BAAS_URL=/api
