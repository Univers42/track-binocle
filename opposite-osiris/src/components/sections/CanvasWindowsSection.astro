					<line x1="266" y1="210" x2="450" y2="210" />
					<line x1="266" y1="226" x2="380" y2="226" />
					<line x1="266" y1="246" x2="420" y2="246" />
					<line x1="266" y1="262" x2="400" y2="262" />
					<line x1="266" y1="278" x2="350" y2="278" />
