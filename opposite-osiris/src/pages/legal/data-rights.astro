---
import Layout from '../../layouts/Layout.astro';
import { DATA_CONTROLLER, POLICY_LAST_UPDATED, POLICY_VERSION } from '../../data/legal';
---

<Layout title="Data Rights — Prismatica" description="Submit GDPR data rights requests to Prismatica.">
	<main class="legal-page section-shell">
		<a href="/" class="legal-page__back">← Back to Prismatica</a>
		<h1>Data Rights Request</h1>
		<p><strong>Version:</strong> {POLICY_VERSION} · <strong>Last updated:</strong> {POLICY_LAST_UPDATED}</p>
		<p>Use this form to request access, deletion, correction, portability, restriction or objection. Unauthenticated requests are recorded by email and manually verified before any disclosure or deletion.</p>

		<form class="data-rights-form" data-gdpr-request-form novalidate>
			<input type="hidden" name="csrf" data-csrf-token />
			<div class="field">
				<label for="rights-email">Email address</label>
				<input id="rights-email" name="email" type="email" autocomplete="email" required />
			</div>
			<div class="field">
				<label for="rights-type">Request type</label>
				<select id="rights-type" name="request_type" required>
					<option value="access">Access my data</option>
					<option value="deletion">Delete my account/data</option>
					<option value="rectification">Correct my data</option>
					<option value="portability">Export portable data</option>
					<option value="restriction">Restrict processing</option>
					<option value="objection">Object to processing</option>
				</select>
			</div>
			<div class="field">
				<label for="rights-message">Additional details</label>
				<textarea id="rights-message" name="message" rows="5" maxlength="1000"></textarea>
			</div>
			<p class="form-note">We may request proof of identity before processing your request. The normal response period is one month.</p>
			<button class="button button--primary" type="submit">Submit request</button>
			<output class="form-status" role="status" aria-live="polite" data-gdpr-request-status></output>
		</form>

		<p>Alternatively, contact <a href={`mailto:${DATA_CONTROLLER.email}`}>{DATA_CONTROLLER.email}</a>.</p>
	</main>
</Layout>
