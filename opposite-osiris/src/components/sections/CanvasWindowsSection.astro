<style is:global>
	.canvas-windows__grid {
		display: grid;
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: center;
	}

	.canvas-windows__copy {
		display: grid;
		justify-items: center;
		gap: 0.9rem;
		max-width: 760px;
		margin-inline: auto;
		text-align: center;
	}

	.canvas-windows .canvas-windows__title {
		font-size: clamp(3rem, 7vw, 6.5rem);
		font-weight: 400;
		line-height: 0.9;
		color: var(--brand-canvas-text);
		text-shadow: 0 0 44px var(--brand-glow-primary);
	}

	.canvas-windows__lede {
		max-width: 68ch;
		text-align: center;
	}

	.canvas-windows__figure {
		position: relative;
		width: min(1080px, 100%);
		margin: 0 auto;
		padding: clamp(0.35rem, 1.2vw, 0.85rem);
		border: 1px solid var(--brand-canvas-line-strong);
		border-radius: clamp(1rem, 2vw, 1.6rem);
		background: color-mix(in srgb, var(--brand-canvas-surface) 72%, transparent);
		box-shadow: var(--system-shadow-3), inset 0 1px 0 color-mix(in srgb, var(--brand-canvas-text) 10%, transparent);
		overflow: hidden;
	}

	.canvas-windows__figure::before {
		content: '';
		position: absolute;
		inset: 4% 12%;
		background: radial-gradient(ellipse, var(--brand-glow-primary), transparent 70%);
		opacity: 0.42;
	}

	.canvas-windows__svg {
		position: relative;
		display: block;
		width: 100%;
		height: auto;
		color: var(--brand-canvas-text);
	}

	.canvas-windows__halo {
		fill: color-mix(in srgb, var(--brand-palette-secondary) 8%, transparent);
		stroke: color-mix(in srgb, var(--brand-palette-secondary) 24%, transparent);
		stroke-width: 1;
	}

	@media (max-width: 760px) {
		.canvas-windows__figure {
			width: 100%;
			overflow: hidden;
		}
		.canvas-windows .canvas-windows__title {
			font-size: clamp(2.7rem, 14vw, 4.6rem);
		}
		.canvas-windows__svg {
			min-width: 0;
		}
	}
</style>
