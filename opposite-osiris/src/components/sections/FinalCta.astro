---
import Button from '../ui/Button.astro';
---

<section class="section section--final final-cta">
	<div class="section__container final-cta__inner" data-scroll-rise>
		<h2 class="final-cta__title">Your backend, ready in an afternoon.</h2>
		<p class="final-cta__lede">Open-source. GDPR-ready. Yours forever.</p>
		<div class="final-cta__actions">
			<Button variant="primary" size="lg" data-open-portal>Start free</Button>
			<Button variant="secondary" size="lg" href="/docs">Read the docs</Button>
		</div>
		<p class="final-cta__meta">No credit card. Self-host whenever you want.</p>
	</div>
</section>

<style is:global>
	.final-cta {
		position: relative;
		isolation: isolate;
		overflow: hidden;
	}
	.final-cta::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			linear-gradient(90deg, transparent, color-mix(in srgb, var(--brand-palette-secondary) 10%, transparent), transparent),
			radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--brand-palette-primary) 18%, transparent), transparent 62%);
	}
	.final-cta__inner {
		position: relative;
		display: grid;
		gap: 0.9rem;
		justify-items: center;
		text-align: center;
		padding-block: clamp(1.5rem, 3.5vw, 3rem);
	}
	.final-cta__title {
		margin: 0;
		max-width: 15ch;
		font-family: var(--brand-font-display);
		font-size: clamp(2.7rem, 6vw, 5.4rem);
		font-weight: 400;
		line-height: 0.96;
		letter-spacing: 0;
		color: var(--brand-canvas-text);
		text-wrap: balance;
	}
	.final-cta__lede {
		margin: 0;
		font-size: clamp(1.05rem, 0.95rem + 0.45vw, 1.25rem);
		color: var(--system-text);
	}
	.final-cta__actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.65rem;
	}
	.final-cta__meta {
		margin: 0.5rem 0 0;
		font-size: 0.9rem;
		color: var(--system-text-muted);
	}
	@media (max-width: 560px) {
		.final-cta__title {
			max-width: 10.5ch;
			font-size: clamp(2.5rem, 12vw, 3.8rem);
		}
		.final-cta__actions {
			width: 100%;
		}
		.final-cta__actions .ui-button {
			flex: 1 1 220px;
		}
	}
</style>
