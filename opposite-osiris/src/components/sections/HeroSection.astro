---
import HeroPortalPreview from '../svg/HeroPortalPreview.astro';
---

<section class="hero section-shell" aria-labelledby="hero-title">
	<div class="hero__copy">
		<p class="eyebrow">The workspace that grows with you</p>
		<h1 id="hero-title">Everything.<br /><span>One Space.</span></h1>
		<svg class="hero-underline" viewBox="0 0 420 38" aria-hidden="true" focusable="false"><path d="M10 22 C76 7, 128 35, 193 17 C268 -4, 326 36, 411 14" /></svg>
		<p class="hero__text">Write, draw, build databases, connect apps — all in one workspace that understands how you think.</p>
		<div class="hero__actions">
			<button class="button button--primary" type="button" data-open-portal>Start your workspace <span aria-hidden="true">→</span></button>
			<button class="button button--connect" type="button" data-open-connect aria-label="Quick connection — open login"><span lang="fr">Connexion rapide</span> <span aria-hidden="true">→</span></button>
			<a class="button button--ghost" href="#powers">Explore the drawings</a>
		</div>
	</div>
	<div class="hero__portal-preview" aria-label="Present and future portal preview">
		<svg class="click-arrow" viewBox="0 0 190 120" aria-hidden="true" focusable="false"><path d="M174 24 C118 6, 54 20, 30 82" marker-end="url(#arrow)" /><text x="34" y="36">↑ open from header</text></svg>
		<div class="thought-bubble" aria-hidden="true">...</div>
		<span class="star s1" aria-hidden="true">✦</span><span class="star s2" aria-hidden="true">✧</span><span class="star s3" aria-hidden="true">✦</span>
		<HeroPortalPreview />
	</div>
</section>
