					<rect x="522" y="486" width="80" height="14" rx="3" />
					<rect x="612" y="486" width="80" height="14" rx="3" />
					<rect x="702" y="486" width="80" height="14" rx="3" />
					<line x1="522" y1="514" x2="780" y2="514" stroke-dasharray="2 3" />
					<line x1="522" y1="530" x2="700" y2="530" stroke-dasharray="2 3" />
					<line x1="522" y1="546" x2="650" y2="546" stroke-dasharray="2 3" />
				</g>

				<g filter="url(#canvas-wobble-tight)" stroke="var(--brand-canvas-text)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
