{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@mini-baas/common": [
        "libs/common/src"
      ],
      "@mini-baas/common/*": [
        "libs/common/src/*"
      ],
      "@mini-baas/database": [
        "libs/database/src"
      ],
      "@mini-baas/database/*": [
        "libs/database/src/*"
      ],
      "@mini-baas/health": [
        "libs/health/src"
      ],
      "@mini-baas/health/*": [
        "libs/health/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}
