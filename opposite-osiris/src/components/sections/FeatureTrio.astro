---
import Card from '../ui/Card.astro';
import Eyebrow from '../brand/Eyebrow.astro';

const features = [
	{
		icon: '⚡',
		title: 'Auth that just works',
		kind: 'auth',
	},
	{
		icon: '◍',
		title: 'PostgREST + Postgres',
		kind: 'database',
	},
	{
		icon: '✦',
		title: 'GDPR by default',
		kind: 'privacy',
	},
];
---

<section class="section section--surface feature-trio" id="product">
	<div class="section__container">
		<header class="section__head">
			<Eyebrow>What you get</Eyebrow>
			<h2 class="section__title">A backend stack you would have built — already built.</h2>
			<p class="section__lede">Three primitives, one Docker Compose file, full keys to the kingdom.</p>
		</header>

		<div class="feature-trio__grid">
			{features.map((feature) => (
				<div data-scroll-grow>
					<Card variant="feature" class="feature-trio__card">
						<span class="feature-trio__icon" aria-hidden="true">{feature.icon}</span>
						<h3 class="ui-card__title">{feature.title}</h3>
						{feature.kind === 'auth' && (
							<p class="ui-card__lede"><span class="term" title="Authentication: proving who a user is before giving access.">Auth</span> with GoTrue under the hood, social providers, magic links, and Turnstile-protected sign-ups out of the box.</p>
						)}
						{feature.kind === 'database' && (
							<p class="ui-card__lede">Your schema is your <abbr title="Application Programming Interface: the contract software uses to talk to other software.">API</abbr>. <span class="term" title="Row-level security: database rules that limit which rows each user may read or change.">Row-level security</span>, typed queries, instant realtime — no glue code.</p>
						)}
						{feature.kind === 'privacy' && (
							<p class="ui-card__lede"><abbr title="General Data Protection Regulation: European privacy law covering personal data.">GDPR</abbr> by default: consent ledger, <abbr title="Data Subject Access Request: a person asking to access, export, correct, or delete their data.">DSAR</abbr> exports, breach response runbook, and <abbr title="European Union.">EU</abbr> data residency baked in.</p>
						)}
					</Card>
				</div>
			))}
		</div>
	</div>
</section>

<style is:global>
	.feature-trio__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
	}
	.feature-trio__card {
		height: 100%;
	}
	.feature-trio__icon {
		display: grid;
		place-items: center;
		width: 44px;
		height: 44px;
		border-radius: var(--system-radius-md);
		background: var(--system-action-secondary-bg);
		color: var(--system-action-bg);
		font-size: 1.25rem;
		font-weight: 700;
	}
</style>
