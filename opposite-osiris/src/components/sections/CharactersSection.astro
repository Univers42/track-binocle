---
import { characterGuides } from '../../data/site';
import CharacterCard from '../ui/CharacterCard.astro';
---

<section id="characters" class="section-shell characters-section" aria-labelledby="characters-title">
	<div class="section-heading compact">
		<p class="eyebrow">Guides</p>
		<h2 id="characters-title">Minimal characters, precise proportions.</h2>
		<p>Reader, Student and Chatter are line-clear companions that guide the story without stealing attention.</p>
	</div>
	<div class="character-grid">
		{characterGuides.map((character) => <CharacterCard character={character} />)}
	</div>
</section>
