			<path d="M16 4 C20 7, 23 12, 24 19 L28 23 L23 24 C21 27, 18 29, 16 30 C14 29, 11 27, 9 24 L4 23 L8 19 C9 12, 12 7, 16 4Z" />
			<path d="M13 20 L19 20" />
