# Project-owned mini-BaaS runtime environment.
# Copy to infrastructure/baas/.env.local or run:
#   node infrastructure/baas/scripts/bootstrap-env.mjs

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-random-password
POSTGRES_DB=postgres
DATABASE_URL=postgres://postgres:replace-with-random-password@postgres:5432/postgres
PGRST_DB_URI=postgres://postgres:replace-with-random-password@postgres:5432/postgres
PGRST_DB_ANON_ROLE=anon

JWT_SECRET=replace-with-random-hex-32-bytes
ANON_KEY=replace-with-generated-anon-jwt
SERVICE_ROLE_KEY=replace-with-generated-service-role-jwt
KONG_PUBLIC_API_KEY=replace-with-generated-anon-jwt
KONG_SERVICE_API_KEY=replace-with-generated-service-role-jwt
KONG_ANON_UUID=cd4f782c-ac87-5081-b322-b54834d15651

PROJECT_INIT_MARKER=track_binocle_20260504
GOTRUE_DB_DATABASE_URL=postgres://postgres:replace-with-random-password@postgres:5432/postgres
GOTRUE_JWT_SECRET=replace-with-random-hex-32-bytes
PGRST_JWT_SECRET=replace-with-random-hex-32-bytes
PG_META_DB_HOST=postgres
PG_META_DB_PORT=5432
PG_META_DB_NAME=postgres
PG_META_DB_USER=postgres
PG_META_DB_PASSWORD=replace-with-random-password
SECRET_KEY_BASE=replace-with-random-secret
VAULT_ENC_KEY=replace-with-32-hex-chars
GOTRUE_SMTP_HOST=mailpit
GOTRUE_SMTP_PORT=1025
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_ADMIN_EMAIL=noreply@mini-baas.local
GOTRUE_SMTP_SENDER_NAME=Prismatica
GOTRUE_SITE_URL=http://localhost:4322
GOTRUE_URI_ALLOW_LIST=http://localhost:4322/**,https://localhost:4322/**,http://localhost:4321/**,https://localhost:4321/**,http://localhost:5173/**,https://localhost:5173/**
