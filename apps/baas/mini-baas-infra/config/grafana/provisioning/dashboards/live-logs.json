{
  "annotations": {
    "list": []
  },
  "description": "Real-time log streaming from all mini-BaaS services via Loki",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Live tail of all service logs — filter by service using the dropdown above",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{compose_project=\"mini-baas\", compose_service=~\"$service\"} |= \"$search\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Live Logs — $service",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Error-level logs across all services",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{compose_project=\"mini-baas\"} |~ \"(?i)(error|fatal|panic|exception|critical)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Errors & Exceptions",
      "type": "logs"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "description": "Log volume per service over time",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "lines/s",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (compose_service) (rate({compose_project=\"mini-baas\"}[$__interval]))",
          "legendFormat": "{{compose_service}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Service",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "observatory",
    "logs",
    "loki"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": ".+",
          "value": ".+"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "definition": "label_values({compose_project=\"mini-baas\"}, compose_service)",
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "query": "label_values({compose_project=\"mini-baas\"}, compose_service)",
        "refresh": 2,
        "regex": "",
        "type": "query"
      },
      {
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "label": "Search",
        "name": "search",
        "options": [],
        "query": "",
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "mini-BaaS Live Logs",
  "uid": "mini-baas-live-logs",
  "version": 1
}
