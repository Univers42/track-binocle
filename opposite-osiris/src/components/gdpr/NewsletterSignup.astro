---
interface Props {
	id?: string;
}

const { id = 'newsletter-signup' } = Astro.props;
---

<form class="newsletter-signup" data-newsletter-signup novalidate>
	<h3>Prismatica newsletter</h3>
	<p>Receive occasional product and privacy-aware workspace updates.</p>
	<div class="field">
		<label for={`${id}-email`}>Email address</label>
		<input id={`${id}-email`} name="email" type="email" autocomplete="email" required />
	</div>
	<label class="consent-toggle" for={`${id}-consent`}>
		<input id={`${id}-consent`} name="newsletter_consent" type="checkbox" required />
		<span>I agree to receive the Prismatica newsletter. I can unsubscribe at any time. See the <a href="/legal/privacy-policy/">Privacy Policy</a>.</span>
	</label>
	<button class="button button--primary" type="submit">Subscribe</button>
	<output class="form-status" role="status" aria-live="polite" data-newsletter-status></output>
</form>
