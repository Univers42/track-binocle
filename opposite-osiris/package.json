{
  "name": "opposite-osiris",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/dev-https.mjs",
    "dev:astro": "astro dev",
    "dev:https": "node scripts/dev-https.mjs",
    "build": "astro build",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "cert:localhost": "sh ../infrastructure/baas/scripts/generate-localhost-cert.sh",
    "cert:trust": "sh ../infrastructure/baas/scripts/trust-localhost-cert.sh",
    "auth:gateway": "node scripts/auth-gateway.mjs",
    "test:security": "node scripts/security/run-all.mjs",
    "test:security:ctf": "node scripts/security/ctf/run-all.mjs",
    "test:smtp": "node --env-file=.env.local scripts/verify-smtp.mjs",
    "test:email": "node --env-file=.env.local scripts/verify-email-delivery.mjs",
    "test:templates": "node scripts/verify-templates.mjs",
    "test:newsletter": "node scripts/verify-newsletter-flow.mjs",
    "test:delivery": "node scripts/verify-smtp-delivery.mjs",
    "verify:csp": "node scripts/verify-csp.mjs",
    "verify:sdk-boundaries": "node scripts/verify-sdk-boundaries.mjs",
    "test:ux": "node scripts/verify-notifications.mjs",
    "reset:database": "node ../infrastructure/baas/scripts/reset-database.mjs",
    "db:reset": "node ../infrastructure/baas/scripts/reset-database.mjs",
    "db:reset:yes": "node ../infrastructure/baas/scripts/reset-database.mjs --yes",
    "baas:verify": "npm run baas:verify:connection && npm run baas:verify:schema && npm run baas:verify:seeds && npm run baas:verify:auth && npm run baas:verify:register",
    "baas:verify:cors": "node scripts/verify-cors.mjs",
    "baas:verify:connection": "node scripts/verify-connection.mjs",
    "baas:verify:schema": "node scripts/verify-schema.mjs",
    "baas:verify:seeds": "node scripts/verify-seeds.mjs",
    "baas:verify:auth": "node scripts/verify-auth.mjs",
    "baas:verify:register": "node scripts/verify-registration-flow.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@mini-baas/js": "file:../infrastructure/baas/sdk",
    "astro": "^6.2.1",
    "sanitize-html": "^2.17.3",
    "sass": "^1.94.2"
  },
  "devDependencies": {
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^5.9.3"
  }
}
