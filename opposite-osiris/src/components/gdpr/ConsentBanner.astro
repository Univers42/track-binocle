---
import { POLICY_VERSION } from '../../data/legal';
---

<section class="consent-banner" data-consent-banner role="dialog" aria-modal="false" aria-labelledby="consent-title" aria-describedby="consent-description" hidden>
	<div class="consent-banner__paper">
		<div>
			<p class="eyebrow">Privacy choices</p>
			<h2 id="consent-title">Choose your consent preferences</h2>
			<p id="consent-description">We only use essential local preferences by default. Optional analytics, newsletter and marketing choices stay off unless you enable them.</p>
			<p class="consent-banner__version">Policy version {POLICY_VERSION}</p>
		</div>
		<div class="consent-banner__actions" aria-label="Quick consent choices">
			<button class="button button--primary" type="button" data-consent-accept-all>Accept all</button>
			<button class="button button--ghost" type="button" data-consent-reject-all>Reject all</button>
			<button class="button button--ghost" type="button" data-consent-manage aria-expanded="false" aria-controls="consent-preferences">Manage preferences</button>
		</div>
		<form id="consent-preferences" class="consent-banner__preferences" data-consent-form hidden>
			<label class="consent-toggle">
				<input type="checkbox" name="analytics" />
				<span><strong>Analytics</strong> — optional audience measurement. Off by default.</span>
			</label>
			<label class="consent-toggle">
				<input type="checkbox" name="newsletter" />
				<span><strong>Newsletter</strong> — occasional product updates. Off by default.</span>
			</label>
			<label class="consent-toggle">
				<input type="checkbox" name="marketing" />
				<span><strong>Marketing</strong> — promotional messages. Off by default.</span>
			</label>
			<div class="consent-banner__actions">
				<button class="button button--primary" type="submit">Save preferences</button>
				<a href="/legal/privacy-policy/">Privacy Policy</a>
			</div>
		</form>
		<noscript>
			<p>JavaScript is disabled. Optional tracking is not loaded. You can read the <a href="/legal/privacy-policy/">Privacy Policy</a>.</p>
		</noscript>
	</div>
</section>
