---
import Layout from '../../layouts/Layout.astro';

const configuredBaasUrl = import.meta.env.PUBLIC_BAAS_URL ?? '/api';
const baasUrl = configuredBaasUrl.replace(/\/$/, '');
const anonKey = import.meta.env.PUBLIC_BAAS_ANON_KEY ?? '';
---

<Layout title="Reset your Prismatica password" description="Choose a new Prismatica password from a recovery email link.">
	<main class="auth-page" data-password-reset data-baas-url={baasUrl} data-anon-key={anonKey}>
		<section class="auth-card" aria-labelledby="reset-title">
			<p class="eyebrow">Password recovery</p>
			<h1 id="reset-title">Choose a new password</h1>
			<p class="auth-card__hint">Use at least 8 characters with uppercase, lowercase, number, and symbol.</p>
			<form class="auth-form" data-reset-form novalidate>
				<div class="field">
					<label for="new-password">New password</label>
					<div class="password-control">
						<input id="new-password" name="password" type="password" autocomplete="new-password" required minlength="8" />
						<button class="password-control__toggle" type="button" data-password-toggle aria-label="Show new password" aria-controls="new-password" aria-pressed="false" title="Show new password">
							<span aria-hidden="true">◉</span>
						</button>
					</div>
					<div class="password-strength" data-password-strength data-strength-level="empty" aria-live="polite">
						<div class="password-strength__meter" aria-hidden="true">
							<span class="password-strength__segment" data-password-segment></span>
							<span class="password-strength__segment" data-password-segment></span>
							<span class="password-strength__segment" data-password-segment></span>
							<span class="password-strength__segment" data-password-segment></span>
						</div>
						<span class="password-strength__label" data-password-strength-label>Enter a password</span>
						<ul class="password-strength__rules" data-password-rules></ul>
					</div>
				</div>
				<div class="field">
					<label for="confirm-password">Confirm new password</label>
					<div class="password-control">
						<input id="confirm-password" name="confirm_password" type="password" autocomplete="new-password" required minlength="8" />
						<button class="password-control__toggle" type="button" data-password-toggle aria-label="Show confirmation password" aria-controls="confirm-password" aria-pressed="false" title="Show confirmation password">
							<span aria-hidden="true">◉</span>
						</button>
					</div>
					<p id="reset-password-match" class="password-match" data-password-match aria-live="polite">Repeat the same password.</p>
				</div>
				<button class="portal-cta" type="submit" disabled aria-label="Update password">Update password →</button>
				<output class="portal-error" data-reset-status role="status" aria-live="polite" aria-atomic="true"></output>
			</form>
			<a class="text-link" href="/">Return home</a>
		</section>
	</main>
	<script>
		import { createClient } from '@mini-baas/js';
		import { notify } from '../../scripts/notifications';
		import { checkPasswordStrength, passwordRuleResults } from '../../scripts/password-strength';

		const root = document.querySelector('[data-password-reset]') as HTMLElement | null;
		const form = root?.querySelector('[data-reset-form]') as HTMLFormElement | null | undefined;
		const status = root?.querySelector('[data-reset-status]');
		const token = new URLSearchParams(window.location.search).get('token');
		const baasUrl = root?.dataset.baasUrl?.replace(/\/$/, '') ?? '';
		const anonKey = root?.dataset.anonKey ?? '';
		const setStatus = (message: string, isError = false) => {
			if (!status) return;
			status.textContent = message;
			status.classList.toggle('is-error', isError);
		};
		const renderStrength = (password: string) => {
			const root = form?.querySelector('[data-password-strength]');
			if (!(root instanceof HTMLElement)) return;
			const result = checkPasswordStrength(password);
			root.dataset.strengthLevel = result.level;
			root.querySelectorAll('[data-password-segment]').forEach((segment, index) => segment.classList.toggle('is-filled', index < result.score));
			const label = root.querySelector('[data-password-strength-label]');
			if (label instanceof HTMLElement) label.textContent = result.level === 'empty' ? 'Enter a password' : `${result.level[0].toUpperCase()}${result.level.slice(1)} password`;
			const rules = root.querySelector('[data-password-rules]');
			if (rules instanceof HTMLUListElement) {
				rules.replaceChildren(...passwordRuleResults(password).map((rule) => {
					const item = document.createElement('li');
					item.className = `password-strength__rule ${rule.passed ? 'is-met' : 'is-unmet'}`;
					item.textContent = rule.label;
					return item;
				}));
			}
		};
		const updateMatch = (password: string, confirm: string) => {
			const match = form?.querySelector('[data-password-match]');
			const hasConfirmation = confirm.length > 0;
			const matches = hasConfirmation && password === confirm;
			if (match instanceof HTMLElement) {
				match.classList.toggle('is-match', matches);
				match.classList.toggle('is-mismatch', hasConfirmation && !matches);
				match.textContent = matches ? 'Passwords match.' : hasConfirmation ? 'Passwords do not match.' : 'Repeat the same password.';
			}
			return matches;
		};
		const refreshSubmitState = () => {
			if (!(form instanceof HTMLFormElement)) return;
			const password = form.elements.namedItem('password');
			const confirm = form.elements.namedItem('confirm_password');
			const button = form.querySelector('button[type="submit"]');
			if (!(password instanceof HTMLInputElement) || !(confirm instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement)) return;
			renderStrength(password.value);
			button.disabled = !(checkPasswordStrength(password.value).passed && updateMatch(password.value, confirm.value) && Boolean(token));
		};
		if (!token) {
			setStatus('This reset link is missing its token.', true);
			notify({ kind: 'error', title: 'Link expired', message: 'This reset link has expired. Request a new one.', duration: 0 });
			form?.querySelector('button[type="submit"]')?.setAttribute('disabled', '');
		}
		form?.querySelectorAll('input[type="password"]').forEach((input) => input.addEventListener('input', refreshSubmitState));
		refreshSubmitState();
		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const password = form.elements.namedItem('password');
			const confirm = form.elements.namedItem('confirm_password');
			if (!(password instanceof HTMLInputElement) || !(confirm instanceof HTMLInputElement)) return;
			if (!checkPasswordStrength(password.value).passed) {
				setStatus('Your password does not meet the security requirements.', true);
				notify({ kind: 'warning', title: 'Password too weak', message: 'Your password does not meet the security requirements.', duration: 5000 });
				password.focus();
				return;
			}
			if (password.value !== confirm.value) {
				setStatus('Both password fields must match.', true);
				notify({ kind: 'warning', title: 'Passwords do not match', message: 'Make sure both fields are identical.', duration: 5000 });
				confirm.focus();
				return;
			}
			if (!token || !baasUrl || !anonKey) {
				setStatus('Password reset is not configured for this environment.', true);
				return;
			}
			const button = form.querySelector('button[type="submit"]');
			button?.setAttribute('disabled', '');
			setStatus('Updating your password…');
			try {
				await createClient({ url: baasUrl, anonKey, accessToken: token, persistSession: false }).auth.updateUser({ password: password.value }, token);
				setStatus('Your password was updated. You can now sign in.');
				notify({ kind: 'success', title: 'Password updated', message: 'Your new password is active. You can now sign in.', duration: 0 });
			} catch {
				setStatus('This reset link has expired. Request a new one.', true);
				notify({ kind: 'error', title: 'Link expired', message: 'This reset link has expired. Request a new one.', duration: 0 });
				button?.removeAttribute('disabled');
			}
		});
	</script>
</Layout>
