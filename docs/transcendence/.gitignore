# ============================================
# Transcendence — .gitignore
# ============================================
# Keep the repo clean: dependencies, build artifacts,
# secrets, IDE files, and generated content stay local.
# ============================================

# ── Dependencies ─────────────────────────────────────
node_modules/
.pnpm-store/
.npm/
.yarn/

# ── Build Outputs ────────────────────────────────────
dist/
build/
.next/
.nuxt/
*.js.map
*.tsbuildinfo

# ── Environment & Secrets ────────────────────────────
# ⚠️ NEVER commit secrets — only .env.example is tracked
.env
.env.local
.env.development
.env.test
.env.production
*.pem
*.key
*.cert
*.p12

# ── Prismatica (separate repo — has its own .git) ───
prismatica/

# ── IDE & Editor ─────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Logs ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Testing ──────────────────────────────────────────
coverage/
.nyc_output/
test-results*.json

# ── Cache ────────────────────────────────────────────
.cache/
.turbo/
.parcel-cache/
.eslintcache
.stylelintcache

# ── Docker (dev data volumes) ────────────────────────
data/

# ── Uploads (user-generated content) ────────────────
uploads/

# ── Temporary ────────────────────────────────────────
.temp/
.tmp/
tmp/
packages/*
packages
packages/.*

# Docusaurus (managed by static_docs/docusaurus/.gitignore)
static_docs/docusaurus/node_modules/
static_docs/docusaurus/.docusaurus/
static_docs/docusaurus/.cache-loader/

# ── Gitflow ──────────────────────────────────────────
gitflow/
