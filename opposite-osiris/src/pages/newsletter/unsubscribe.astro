---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Unsubscribe from Prismatica" description="Unsubscribe from the Prismatica newsletter.">
	<main class="auth-page" data-newsletter-unsubscribe>
		<section class="auth-card" aria-labelledby="newsletter-unsubscribe-title">
			<p class="eyebrow">Newsletter</p>
			<h1 id="newsletter-unsubscribe-title">Unsubscribing…</h1>
			<p data-newsletter-unsubscribe-status role="status" aria-live="polite">Processing your unsubscribe request.</p>
			<a class="text-link" href="/">Return home</a>
		</section>
	</main>
	<script>
		const root = document.querySelector('[data-newsletter-unsubscribe]') as HTMLElement | null;
		const status = root?.querySelector('[data-newsletter-unsubscribe-status]');
		const token = new URLSearchParams(window.location.search).get('token');
		const setStatus = (message: string, isError = false) => {
			if (!status) return;
			status.textContent = message;
			status.classList.toggle('is-error', isError);
		};
		async function unsubscribe() {
			if (!token) {
				setStatus('This unsubscribe link is missing its token.', true);
				return;
			}
			try {
				const response = await fetch('/api/newsletter/unsubscribe', {
					method: 'POST',
					headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
					body: JSON.stringify({ token }),
				});
				if (!response.ok) throw new Error('newsletter_unsubscribe_failed');
			} catch {
				setStatus('This unsubscribe link is invalid or has already been used.', true);
				return;
			}
			setStatus('You have been unsubscribed from the Prismatica newsletter.');
		}
		void unsubscribe().catch(() => setStatus('Could not unsubscribe right now. Please try again later.', true));
	</script>
</Layout>
