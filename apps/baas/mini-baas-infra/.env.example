# -----------------------------------------------------------------------------
# Standalone mini-baas-infra runtime
# Managed by apps/baas/scripts/vault-env.mjs.
# Copy to the matching .env file only for local development; Vault is the source of truth after seeding.
# -----------------------------------------------------------------------------

# REQUIRED: Required. The service will not boot, authenticate, or bridge correctly without these keys.
# Required. Public anon JWT used by browser and gateway calls. If omitted: startup, auth, or bridge flow can fail.
ANON_KEY=replace-with-anon-key

# Required. Internal Postgres URL used by BaaS services. If omitted: startup, auth, or bridge flow can fail.
DATABASE_URL=postgres://postgres:replace-with-postgres-secret@postgres:5432/postgres

# Required. Runtime configuration key for this service. If omitted: startup, auth, or bridge flow can fail.
EMAIL_FROM=replace-with-email-from

# Required. GoTrue authentication service configuration. If omitted: startup, auth, or bridge flow can fail.
GOTRUE_MAILER_AUTOCONFIRM=true

# Required. GoTrue authentication service configuration. If omitted: startup, auth, or bridge flow can fail.
GOTRUE_MAILER_TEMPLATES_CONFIRMATION=replace-with-gotrue-mailer-templates-confirmation

# Required. GoTrue authentication service configuration. If omitted: startup, auth, or bridge flow can fail.
GOTRUE_MAILER_TEMPLATES_RECOVERY=replace-with-gotrue-mailer-templates-recovery

# Required. GoTrue authentication service configuration. If omitted: startup, auth, or bridge flow can fail.
GOTRUE_MAILER_URLPATHS_CONFIRMATION=replace-with-gotrue-mailer-urlpaths-confirmation

# Required. GoTrue authentication service configuration. If omitted: startup, auth, or bridge flow can fail.
GOTRUE_MAILER_URLPATHS_RECOVERY=replace-with-gotrue-mailer-urlpaths-recovery

# Required. Signing secret shared by GoTrue, PostgREST, Kong, and generated JWTs. If omitted: startup, auth, or bridge flow can fail.
JWT_SECRET=replace-with-jwt-secret

# Required. Runtime configuration key for this service. If omitted: startup, auth, or bridge flow can fail.
KONG_ANON_UUID=cd4f782c-ac87-5081-b322-b54834d15651

# Required. Public API key injected into Kong routing configuration. If omitted: startup, auth, or bridge flow can fail.
KONG_PUBLIC_API_KEY=replace-with-kong-public-api-key

# Required. Privileged service key injected into Kong routing configuration. If omitted: startup, auth, or bridge flow can fail.
KONG_SERVICE_API_KEY=replace-with-kong-service-api-key

# Required. PostgREST configuration consumed by the BaaS gateway. If omitted: startup, auth, or bridge flow can fail.
PGRST_DB_ANON_ROLE=anon

# Required. PostgREST configuration consumed by the BaaS gateway. If omitted: startup, auth, or bridge flow can fail.
PGRST_DB_SCHEMA=public

# Required. PostgREST database connection string. If omitted: startup, auth, or bridge flow can fail.
PGRST_DB_URI=postgres://postgres:replace-with-postgres-secret@postgres:5432/postgres

# Required. Postgres connection setting for the local Docker database. If omitted: startup, auth, or bridge flow can fail.
POSTGRES_DB=postgres

# Required. Postgres connection setting for the local Docker database. If omitted: startup, auth, or bridge flow can fail.
POSTGRES_PASSWORD=replace-with-postgres-password

# Required. Postgres connection setting for the local Docker database. If omitted: startup, auth, or bridge flow can fail.
POSTGRES_USER=postgres

# Required. Privileged JWT used by trusted server-side components only. If omitted: startup, auth, or bridge flow can fail.
SERVICE_ROLE_KEY=replace-with-service-role-key

# Required. Local encryption material used by Vault-backed BaaS helpers. If omitted: startup, auth, or bridge flow can fail.
VAULT_ENC_KEY=replace-with-vault-enc-key

# RECOMMENDED: Recommended. Defaults keep local Docker usable, but set these to make routing, email, and integrations explicit.
# Recommended. Service URL used for local routing. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
API_EXTERNAL_URL=https://localhost:8000/auth/v1

# Recommended. GoTrue authentication service configuration. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GOTRUE_SITE_URL=https://localhost:4322

# Recommended. GoTrue authentication service configuration. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
GOTRUE_URI_ALLOW_LIST=https://localhost:4322/**,https://localhost:3001/**

# Recommended. Allowed CORS origin for Kong gateway responses. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
KONG_CORS_ORIGIN_APP=https://localhost:3000

# Recommended. Allowed CORS origin for Kong gateway responses. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
KONG_CORS_ORIGIN_FRONTEND=https://localhost:4322

# Recommended. Allowed CORS origin for Kong gateway responses. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
KONG_CORS_ORIGIN_PLAYGROUND=https://localhost:3100

# Recommended. Allowed CORS origin for Kong gateway responses. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
KONG_CORS_ORIGIN_STUDIO=https://localhost:3001

# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
PUBLIC_SITE_URL=https://localhost:4322

# OPTIONAL: Optional. Leave empty to disable the integration and gain a smaller local attack surface.
# Optional. Service URL used for local routing. If omitted: the related integration is disabled, reducing local secret sprawl.
ADAPTER_REGISTRY_DATABASE_URL=http://localhost:3000

# Optional. Service URL used for local routing. If omitted: the related integration is disabled, reducing local secret sprawl.
ADAPTER_REGISTRY_URL=http://localhost:3000

