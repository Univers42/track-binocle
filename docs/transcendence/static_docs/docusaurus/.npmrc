# Override parent .npmrc — Docusaurus uses npm, not pnpm
strict-peer-dependencies=false
auto-install-peers=false
prefer-offline=false
legacy-peer-deps=true
fund=false
audit=false

# Node.js 25 ships a native localStorage that throws SecurityError unless
# --localstorage-file is set. Docusaurus SSG hits it via the eval package.
node-options=--localstorage-file=/tmp/docusaurus-localstorage.json
