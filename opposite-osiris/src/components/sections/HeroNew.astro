---
import Button from '../ui/Button.astro';
import Eyebrow from '../brand/Eyebrow.astro';
---

<section class="section section--hero hero-new" id="top">
	<div class="section__container hero-new__grid">
		<div class="hero-new__copy" data-scroll-rise>
			<Eyebrow icon="✶">Open-source BaaS for product teams</Eyebrow>
			<h1 class="section__title hero-new__title">
				Everything.
				<span class="hero-new__glow-word">One Space.</span>
			</h1>
			<p class="section__lede hero-new__lede">
				Prismatica keeps auth, database, files, email, dashboards, and product workflows
				on one self-hostable backend canvas. GDPR-ready, fully typed, and yours forever.
			</p>
			<div class="hero-new__cta">
				<Button variant="primary" size="lg" data-open-portal>Start free</Button>
				<Button variant="secondary" size="lg" href="#product">See it in action</Button>
			</div>
			<ul class="hero-new__bullets" role="list">
				<li>No credit card</li>
				<li>Self-host or cloud</li>
				<li>EU data residency</li>
			</ul>
		</div>

		<div class="hero-new__art" data-scroll-grow aria-hidden="true">
			<div class="hero-new__frame">
				<div class="hero-new__chrome">
					<span></span><span></span><span></span>
					<code>app.prismatica.dev</code>
				</div>
				<div class="hero-new__viewport">
					<div class="hero-new__panel hero-new__panel--meta">
						<strong>auth.users</strong>
						<span class="ui-badge ui-badge--success ui-badge--sm">live</span>
					</div>
					<div class="hero-new__panel hero-new__panel--rows">
						<div><span>amelia@studio.io</span><em>verified</em></div>
						<div><span>jonas@kollektiv.de</span><em>pending</em></div>
						<div><span>noor@axiomlab.nl</span><em>verified</em></div>
					</div>
					<div class="hero-new__panel hero-new__panel--query">
						<code>POST /api/users<br/>Authorization: Bearer •••</code>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style is:global>
	.hero-new__grid {
		display: grid;
		gap: clamp(1.5rem, 4vw, 3rem);
		align-items: center;
		justify-items: center;
	}

	.hero-new__copy {
		display: grid;
		gap: 1rem;
		justify-items: center;
		max-width: 940px;
		text-align: center;
	}

	.hero-new .hero-new__title {
		max-width: min(10.5ch, 94vw);
		font-family: var(--brand-font-display);
		font-size: clamp(4.8rem, 10vw, 10.5rem);
		font-weight: 400;
		line-height: 0.86;
		letter-spacing: 0;
		text-align: center;
		color: var(--brand-canvas-text);
	}

	.hero-new__glow-word {
		display: inline-block;
		color: transparent;
		background: linear-gradient(90deg, var(--brand-palette-primary), var(--brand-palette-secondary), var(--brand-palette-warm));
		background-clip: text;
		-webkit-background-clip: text;
		text-shadow: 0 0 42px var(--brand-glow-primary), 0 0 72px var(--brand-glow-secondary);
	}

	.hero-new__lede {
		max-width: 66ch;
		text-align: center;
	}

	.hero-new__cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: 0.4rem;
	}

	.hero-new__bullets {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 1.5rem;
		margin: 0.4rem 0 0;
		padding: 0;
		list-style: none;
		font-size: 0.88rem;
		color: var(--system-text-muted);
	}
	.hero-new__bullets li::before {
		content: '✓';
		display: inline-block;
		margin-right: 0.4rem;
		color: var(--brand-checkmark);
		font-weight: 700;
	}

	.hero-new__art {
		position: relative;
		width: min(940px, 100%);
	}

	.hero-new__art::before {
		content: '';
		position: absolute;
		inset: 12% 6%;
		z-index: -1;
		background: radial-gradient(ellipse, var(--brand-glow-secondary), transparent 72%);
		opacity: 0.52;
	}

	.hero-new__frame {
		display: grid;
		grid-template-rows: auto 1fr;
		border: 1px solid var(--brand-canvas-line-strong);
		border-radius: var(--system-radius-xl);
		background: var(--brand-canvas-panel-bg-strong);
		box-shadow: var(--system-shadow-3);
		overflow: hidden;
	}

	.hero-new__chrome {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.55rem 0.9rem;
		background: color-mix(in srgb, var(--brand-canvas-bg) 76%, transparent);
		border-bottom: 1px solid var(--brand-canvas-line);
		font-family: var(--system-font-mono);
		font-size: 0.78rem;
		color: var(--system-text-muted);
	}
	.hero-new__chrome span {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--system-border-strong);
	}
	.hero-new__chrome span:first-child { background: var(--brand-window-close); }
	.hero-new__chrome span:nth-child(2) { background: var(--brand-window-minimize); }
	.hero-new__chrome span:nth-child(3) { background: var(--brand-window-maximize); }
	.hero-new__chrome code {
		margin-left: 0.5rem;
	}

	.hero-new__viewport {
		display: grid;
		gap: 0.75rem;
		padding: 1rem;
		background:
			linear-gradient(90deg, var(--brand-canvas-line) 1px, transparent 1px) 0 0 / calc(var(--brand-canvas-grid-size) / 2) calc(var(--brand-canvas-grid-size) / 2),
			linear-gradient(180deg, var(--brand-canvas-line) 1px, transparent 1px) 0 0 / calc(var(--brand-canvas-grid-size) / 2) calc(var(--brand-canvas-grid-size) / 2),
			var(--brand-canvas-bg-2);
	}

	.hero-new__panel {
		padding: 0.7rem 0.9rem;
		border: 1px solid var(--brand-canvas-line-strong);
		border-radius: var(--system-radius-md);
		background: color-mix(in srgb, var(--brand-canvas-surface) 86%, transparent);
		font-size: 0.85rem;
		color: var(--system-text);
	}
	.hero-new__panel--meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-weight: 600;
		color: var(--system-text-strong);
	}
	.hero-new__panel--rows div {
		display: flex;
		justify-content: space-between;
		padding: 0.35rem 0;
		border-bottom: 1px dashed var(--system-divider);
	}
	.hero-new__panel--rows div:last-child {
		border-bottom: 0;
	}
	.hero-new__panel--rows em {
		font-style: normal;
		font-size: 0.78rem;
		color: var(--system-text-muted);
	}
	.hero-new__panel--query {
		font-family: var(--system-font-mono);
		font-size: 0.78rem;
		background: color-mix(in srgb, var(--brand-canvas-bg) 82%, transparent);
	}

	@media (max-width: 700px) {
		.hero-new .hero-new__title {
			max-width: min(9.2ch, 96vw);
			font-size: clamp(3.35rem, 17vw, 5.6rem);
			line-height: 0.86;
		}
		.hero-new__cta,
		.hero-new__bullets {
			justify-content: center;
		}
	}
</style>
