---
import Eyebrow from '../brand/Eyebrow.astro';
---

<section class="section section--sunken product-showcase">
	<div class="section__container">
		<header class="section__head">
			<Eyebrow>Inside the studio</Eyebrow>
			<h2 class="section__title">One Compose file. Your whole backend.</h2>
			<p class="section__lede">Spin up Kong, GoTrue, PostgREST, Postgres, MailHog and your front-end in a single command — locally or on your VPS.</p>
		</header>

		<div class="product-showcase__frame" data-scroll-grow>
			<div class="product-showcase__chrome" aria-hidden="true">
				<span></span><span></span><span></span>
				<code>docker compose up</code>
			</div>
			<div class="product-showcase__viewport">
				<svg viewBox="0 0 800 360" role="img" aria-label="Architecture diagram showing Kong gateway routing to GoTrue, PostgREST, MailHog, and Postgres" class="product-showcase__svg">
					<defs>
						<marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
							<path d="M0 0 L10 5 L0 10 z" fill="currentColor" />
						</marker>
					</defs>

					<g class="ps-node ps-node--gateway">
						<rect x="40" y="140" width="140" height="80" rx="14" />
						<text x="110" y="175" text-anchor="middle">Kong</text>
						<text x="110" y="200" text-anchor="middle" class="ps-sub">API gateway</text>
					</g>

					<g class="ps-node">
						<rect x="280" y="40" width="170" height="78" rx="14" />
						<text x="365" y="74" text-anchor="middle">GoTrue</text>
						<text x="365" y="98" text-anchor="middle" class="ps-sub">Auth · sessions</text>
					</g>

					<g class="ps-node">
						<rect x="280" y="148" width="170" height="78" rx="14" />
						<text x="365" y="183" text-anchor="middle">PostgREST</text>
						<text x="365" y="206" text-anchor="middle" class="ps-sub">REST over Postgres</text>
					</g>

					<g class="ps-node">
						<rect x="280" y="256" width="170" height="78" rx="14" />
						<text x="365" y="291" text-anchor="middle">MailHog</text>
						<text x="365" y="314" text-anchor="middle" class="ps-sub">SMTP capture</text>
					</g>

					<g class="ps-node ps-node--db">
						<rect x="560" y="148" width="180" height="78" rx="14" />
						<text x="650" y="183" text-anchor="middle">Postgres</text>
						<text x="650" y="206" text-anchor="middle" class="ps-sub">Your data — RLS on</text>
					</g>

					<g class="ps-edges">
						<line x1="180" y1="170" x2="280" y2="80"  marker-end="url(#arrow)" />
						<line x1="180" y1="180" x2="280" y2="187" marker-end="url(#arrow)" />
						<line x1="180" y1="190" x2="280" y2="295" marker-end="url(#arrow)" />
						<line x1="450" y1="187" x2="560" y2="187" marker-end="url(#arrow)" />
						<line x1="450" y1="79"  x2="560" y2="170" marker-end="url(#arrow)" />
					</g>
				</svg>

				<aside class="product-showcase__call product-showcase__call--a">
					<strong>Single ingress.</strong> One signed JWT. CORS, rate-limit and Turnstile validated at the edge.
				</aside>
				<aside class="product-showcase__call product-showcase__call--b">
					<strong>Schema = API.</strong> Add a column → REST endpoint updates instantly.
				</aside>
			</div>
		</div>
	</div>
</section>

<style is:global>
	.product-showcase__frame {
		position: relative;
		max-width: 980px;
		margin: 0 auto;
		border: 1px solid var(--system-border-strong);
		border-radius: var(--system-radius-xl);
		background: var(--system-surface);
		box-shadow: var(--system-shadow-3);
		overflow: hidden;
	}

	.product-showcase__chrome {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.55rem 0.9rem;
		background: var(--system-surface-sunken);
		border-bottom: 1px solid var(--system-border);
		font-family: var(--system-font-mono);
		font-size: 0.78rem;
		color: var(--system-text-muted);
	}
	.product-showcase__chrome span {
		width: 10px; height: 10px; border-radius: 50%; background: var(--system-border-strong);
	}
	.product-showcase__chrome span:first-child { background: var(--brand-window-close); }
	.product-showcase__chrome span:nth-child(2) { background: var(--brand-window-minimize); }
	.product-showcase__chrome span:nth-child(3) { background: var(--brand-window-maximize); }

	.product-showcase__viewport {
		position: relative;
		padding: 1.25rem;
	}

	.product-showcase__svg {
		display: block;
		width: 100%;
		height: auto;
		font-family: var(--system-font-sans);
		color: var(--system-text-muted);
	}

	.ps-node rect {
		fill: var(--system-surface-raised);
		stroke: var(--system-border-strong);
		stroke-width: 1.4;
	}
	.ps-node--gateway rect {
		fill: var(--system-action-secondary-bg);
		stroke: var(--system-action-bg);
	}
	.ps-node--db rect {
		fill: color-mix(in srgb, var(--system-info-bg) 70%, var(--system-surface));
		stroke: var(--system-info-border);
	}
	.ps-node text {
		fill: var(--system-text-strong);
		font-size: 16px;
		font-weight: 700;
	}
	.ps-node .ps-sub {
		fill: var(--system-text-muted);
		font-size: 11px;
		font-weight: 500;
	}
	.ps-edges line {
		stroke: var(--system-border-strong);
		stroke-width: 1.6;
		color: var(--system-border-strong);
	}

	.product-showcase__call {
		position: absolute;
		max-width: 220px;
		padding: 0.55rem 0.75rem;
		background: var(--system-surface);
		border: 1px solid var(--system-border);
		border-radius: var(--system-radius-md);
		font-size: 0.82rem;
		color: var(--system-text);
		box-shadow: var(--system-shadow-1);
	}
	.product-showcase__call strong {
		display: block;
		color: var(--system-text-strong);
	}
	.product-showcase__call--a { top: 1.5rem; right: 1.5rem; }
	.product-showcase__call--b { bottom: 1.5rem; left: 1.5rem; }

	@media (max-width: 720px) {
		.product-showcase__call { display: none; }
	}
</style>
