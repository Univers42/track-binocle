---
import { Image } from 'astro:assets';
import { assetIcons } from '../../data/site';
import workspaceConcept from '../../assets/ChatGPT Image May 1, 2026, 09_43_58 PM.png';
import designSurface from '../../assets/design.png.png';
import kanbanView from '../../assets/kanban.png.png';
import designIcon from '../../assets/design-v2.png.png';
import { safePublicAssetPath } from '../../lib/media-security.mjs';

const assetPath = (fileName: string): string => safePublicAssetPath(fileName, import.meta.env.BASE_URL);

const mediaFeatures = [
	{
		title: 'Workspace concept',
		description: 'A broad overview of the all-in-one workspace story.',
		alt: 'Wide concept view of a creative Prismatica workspace with notebook-style surfaces and connected planning areas.',
		image: workspaceConcept,
		width: 1536,
		height: 1024,
		wide: true,
	},
	{
		title: 'Interface mockup',
		description: 'Panels, notes and structured views share one canvas.',
		alt: 'Prismatica interface mockup showing a structured workspace with multiple panels for planning and content.',
		image: assetPath('image%206.svg'),
		width: 1005,
		height: 670,
	},
	{
		title: 'Design surface',
		description: 'Creative work remains close to the operating data.',
		alt: 'Design workspace screenshot with visual planning blocks and a hand-drawn interface style.',
		image: designSurface,
		width: 1022,
		height: 639,
	},
	{
		title: 'Kanban view',
		description: 'Tasks can move through reliable team workflows.',
		alt: 'Kanban board screenshot with organized cards for tracking work across stages.',
		image: kanbanView,
		width: 954,
		height: 597,
	},
];

const icons = [
	assetPath('product.png.svg'),
	assetPath('marketing.png.svg'),
	assetPath('operations.png.svg'),
	assetPath('hr-v2.png.svg'),
	'',
	assetPath('span.svg'),
	assetPath('span%20%281%29.svg'),
];
---

<section id="media-assets" class="section-shell media-assets-section" aria-labelledby="media-assets-title">
	<div class="section-heading compact">
		<p class="eyebrow">Visual workspace library</p>
		<h2 id="media-assets-title">Product screenshots and team icons, described in text.</h2>
		<p>The image files in the asset folder are used here with meaningful alternative text, visible captions and high-contrast supporting copy so the visuals never carry information alone.</p>
	</div>
	<div class="media-showcase" aria-label="Product preview screenshots">
		{mediaFeatures.map((feature) => (
			<figure class:list={["media-feature", feature.wide && "media-feature--wide"]}>
				{typeof feature.image === 'string'
					? <img src={feature.image} width={feature.width} height={feature.height} loading="lazy" decoding="async" alt={feature.alt} />
					: <Image src={feature.image} width={feature.width} height={feature.height} loading="lazy" decoding="async" alt={feature.alt} />}
				<figcaption>
					<strong>{feature.title}</strong>
					<span>{feature.description}</span>
				</figcaption>
			</figure>
		))}
	</div>
	<ul class="asset-icon-grid" aria-label="Team and department icons">
		{assetIcons.map((icon, index) => (
			<li>
				<div class="icon-wrap">
					{index === 4
						? <Image src={designIcon} width={70} height={70} loading="lazy" decoding="async" alt={icon.alt} />
						: <img src={icons[index]} width="70" height="70" loading="lazy" decoding="async" alt={icon.alt} />}
				</div>
				<span>{icon.label}</span>
			</li>
		))}
	</ul>
</section>
