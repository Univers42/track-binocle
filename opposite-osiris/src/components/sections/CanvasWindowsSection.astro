---
import Eyebrow from '../brand/Eyebrow.astro';
---

<section class="section section--surface canvas-windows" id="canvas">
	<div class="section__container canvas-windows__grid">
		<header class="canvas-windows__copy" data-scroll-rise>
			<Eyebrow icon="✶">Workspace anatomy</Eyebrow>
			<h2 class="section__title canvas-windows__title">One canvas, many windows.</h2>
			<p class="section__lede canvas-windows__lede">
				Notes, auth, metrics, Postgres rows, email events, and product workflows all live in one
				place without losing the backend wiring underneath.
			</p>
		</header>

		<figure class="canvas-windows__figure" data-scroll-grow>
			<svg class="canvas-windows__svg" viewBox="0 0 1100 640" xmlns="http://www.w3.org/2000/svg" fill="none" role="img" aria-labelledby="canvas-windows-title canvas-windows-desc">
				<title id="canvas-windows-title">One Prismatica canvas with several product windows</title>
				<desc id="canvas-windows-desc">A hand-drawn dashboard showing notes, charts, assistant context, Postgres rows, privacy panels, sharing controls, and code extensions.</desc>
				<defs>
					<filter id="canvas-wobble" x="-5%" y="-5%" width="110%" height="110%">
						<feTurbulence type="fractalNoise" baseFrequency="0.02" numOctaves="2" seed="3" />
						<feDisplacementMap in="SourceGraphic" scale="2.4" />
					</filter>
					<filter id="canvas-wobble-tight" x="-5%" y="-5%" width="110%" height="110%">
						<feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="2" seed="7" />
						<feDisplacementMap in="SourceGraphic" scale="1.8" />
					</filter>
					<pattern id="canvas-dots" width="14" height="14" patternUnits="userSpaceOnUse">
						<circle cx="2" cy="2" r="1" fill="var(--brand-canvas-text-muted)" opacity="0.42" />
					</pattern>
				</defs>

				<rect x="0" y="0" width="1100" height="640" fill="url(#canvas-dots)" opacity="0.46" />
				<rect class="canvas-windows__halo" x="180" y="84" width="760" height="458" rx="24" />

				<g filter="url(#canvas-wobble)" stroke="var(--brand-canvas-text)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
					<rect x="120" y="60" width="860" height="520" rx="12" />
					<line x1="120" y1="100" x2="980" y2="100" />
					<circle cx="146" cy="80" r="5" fill="var(--brand-window-close)" stroke="none" />
					<circle cx="166" cy="80" r="5" fill="var(--brand-window-minimize)" stroke="none" />
					<circle cx="186" cy="80" r="5" fill="var(--brand-window-maximize)" stroke="none" />
					<rect x="220" y="70" width="180" height="22" rx="4" />
					<line x1="430" y1="80" x2="500" y2="80" stroke-dasharray="4 4" />
					<rect x="500" y="70" width="100" height="22" rx="4" />
					<line x1="220" y1="100" x2="220" y2="580" />
					<rect x="140" y="120" width="60" height="14" rx="3" />
					<rect x="140" y="146" width="70" height="10" rx="3" />
					<rect x="140" y="166" width="50" height="10" rx="3" />
					<rect x="140" y="186" width="64" height="10" rx="3" />
					<line x1="135" y1="208" x2="205" y2="208" />
					<rect x="140" y="220" width="60" height="14" rx="3" />
					<rect x="140" y="246" width="70" height="10" rx="3" />
					<rect x="140" y="266" width="46" height="10" rx="3" />
				</g>

				<g filter="url(#canvas-wobble-tight)" stroke="var(--brand-canvas-text)" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
					<rect x="250" y="130" width="240" height="170" rx="8" />
					<line x1="250" y1="158" x2="490" y2="158" />
					<text x="262" y="150" font-family="var(--brand-font-annotation)" font-size="14" fill="var(--brand-canvas-text)" stroke="none">notes.md</text>
