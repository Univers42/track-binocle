# Astro exposes only PUBLIC_* variables to browser code.
PUBLIC_BAAS_URL=/api
PUBLIC_BAAS_ANON_KEY=replace-with-anon-key-from-mini-baas-env
PUBLIC_SITE_URL=http://localhost:4322
# Optional local HTTPS. Run npm run cert:localhost, npm run cert:trust, then npm run dev:https.
ASTRO_DEV_HOST=localhost
ASTRO_DEV_PORT=4322
ASTRO_DEV_HTTPS=false
ASTRO_DEV_HTTPS_KEY=../infrastructure/baas/certs/localhost-key.pem
ASTRO_DEV_HTTPS_CERT=../infrastructure/baas/certs/localhost.pem
# When ASTRO_DEV_HTTPS=true, set PUBLIC_SITE_URL=https://localhost:4322.
PUBLIC_AUTH_GATEWAY_URL=/api/auth
PUBLIC_PORTAL_URL=https://portal.example.com/sign-in
PUBLIC_AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_REQUIRE_EMAIL_VERIFICATION=true
# GoTrue itself should not auto-confirm outside throwaway local development.
GOTRUE_MAILER_AUTOCONFIRM=false
# For local-only account-creation tests, set both AUTH_REQUIRE_EMAIL_VERIFICATION and PUBLIC_AUTH_REQUIRE_EMAIL_VERIFICATION to false.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_BYPASS_LOCAL=true

# If the project is later migrated to Next.js, mirror these names:
NEXT_PUBLIC_BAAS_URL=/api
NEXT_PUBLIC_BAAS_ANON_KEY=replace-with-anon-key-from-mini-baas-env

# Titan SMTP transactional email settings.
# Real values belong only in .env.local or a production secret store.
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_ENCRYPTION=SSL
SMTP_USERNAME=your-email@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Prismatica
SMTP_FROM_ADDRESS=your-email@yourdomain.com
