---
import Layout from '../../layouts/Layout.astro';
import { DATA_CONTROLLER, POLICY_LAST_UPDATED, POLICY_VERSION } from '../../data/legal';
---

<Layout title="Terms of Service — Prismatica" description="Prismatica terms of service.">
	<main class="legal-page section-shell">
		<a href="/" class="legal-page__back">← Back to Prismatica</a>
		<h1>Terms of Service</h1>
		<p><strong>Version:</strong> {POLICY_VERSION} · <strong>Last updated:</strong> {POLICY_LAST_UPDATED}</p>

		<section>
			<h2>Service description</h2>
			<p>Prismatica is a workspace prototype for notes, dashboards, collaborative content, automations and data-connected interfaces.</p>
		</section>

		<section>
			<h2>Acceptance</h2>
			<p>By creating an account or using the authenticated workspace, you accept these Terms of Service and the Privacy Policy. If you do not agree, do not create an account or use the service.</p>
		</section>

		<section>
			<h2>User obligations</h2>
			<ul>
				<li>Provide accurate account information.</li>
				<li>Keep credentials confidential.</li>
				<li>Use the service only for lawful purposes.</li>
				<li>Respect intellectual property, privacy and security rules.</li>
			</ul>
		</section>

		<section>
			<h2>Prohibited uses</h2>
			<p>You must not attempt unauthorised access, attack the service, upload unlawful content, interfere with other users, or use the service for spam, fraud, harassment or illegal surveillance.</p>
		</section>

		<section>
			<h2>Liability</h2>
			<p>The service is provided as a development workspace and prototype unless a separate written agreement states otherwise. Liability is limited to direct, foreseeable damage caused by proven fault, to the maximum extent permitted by law.</p>
		</section>

		<section>
			<h2>Governing law and jurisdiction</h2>
			<p>These terms are governed by French law. Subject to mandatory consumer rules, disputes fall under the jurisdiction of the competent courts of Paris, France.</p>
		</section>

		<section>
			<h2>Contact</h2>
			<p>{DATA_CONTROLLER.name}, {DATA_CONTROLLER.address}. Contact: <a href={`mailto:${DATA_CONTROLLER.email}`}>{DATA_CONTROLLER.email}</a>.</p>
		</section>
	</main>
</Layout>
