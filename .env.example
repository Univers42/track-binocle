# -----------------------------------------------------------------------------
# Root osionos bridge runtime
# Managed by infrastructure/baas/scripts/vault-env.mjs.
# Copy to the matching .env file only for local development; Vault is the source of truth after seeding.
# -----------------------------------------------------------------------------

# REQUIRED: Required. The service will not boot, authenticate, or bridge correctly without these keys.
# Required. Origin accepted by the osionos bridge API. If omitted: startup, auth, or bridge flow can fail.
OSIONOS_ALLOWED_ORIGIN=http://localhost:3001

# Required. Secret used by osionos to sign local app sessions. If omitted: startup, auth, or bridge flow can fail.
OSIONOS_APP_SESSION_SECRET=replace-with-osionos-app-session-secret

# Required. Browser-facing osionos app URL used in bridge redirects. If omitted: startup, auth, or bridge flow can fail.
OSIONOS_APP_URL=http://localhost:3001

# Required. Salt used to hash bridged email identities before persistence. If omitted: startup, auth, or bridge flow can fail.
OSIONOS_BRIDGE_EMAIL_HASH_SALT=replace-with-osionos-bridge-email-hash-salt

# Required. Shared secret used by the website auth gateway to request osionos bridge tokens. If omitted: startup, auth, or bridge flow can fail.
OSIONOS_BRIDGE_SHARED_SECRET=replace-with-osionos-bridge-shared-secret

# RECOMMENDED: Recommended. Defaults keep local Docker usable, but set these to make routing, email, and integrations explicit.
# Recommended. Browser-exposed configuration. Never put private secrets in this key. If omitted: Docker defaults are used, which is fine for local dev but less explicit for the team.
PUBLIC_OSIONOS_APP_URL=http://localhost:3001

# OPTIONAL: Optional. Leave empty to disable the integration and gain a smaller local attack surface.
# Optional. Runtime configuration key for this service. If omitted: the related integration is disabled, reducing local secret sprawl.
SONAR_TOK=
