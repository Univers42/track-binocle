---
import chatterSvg from '../../assets/draw/character-chatter.svg?raw';
import readerSvg from '../../assets/draw/character-reader.svg?raw';
import studentSvg from '../../assets/draw/character-student.svg?raw';
import type { CharacterGuide } from '../../types/content';

type Props = {
	kind: CharacterGuide['kind'];
};

const { kind } = Astro.props;

const characterSvgs: Record<CharacterGuide['kind'], string> = {
	reader: readerSvg,
	student: studentSvg,
	chatter: chatterSvg,
};
---

<div class="character-svg character-svg--exact" set:html={characterSvgs[kind]} />
