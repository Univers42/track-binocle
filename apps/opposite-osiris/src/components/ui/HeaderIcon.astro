		</svg>
	) : (
		<svg class="header-icon" viewBox="0 0 32 32" aria-hidden="true" focusable="false">
			<path d="M12 17 C10 15, 10 11, 12 9 C14 7, 18 7, 20 9 C22 11, 22 15, 20 17 C18 19, 14 19, 12 17Z" />
			<path d="M16 18 L16 28" />
