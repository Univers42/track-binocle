---
import Layout from '../../layouts/Layout.astro';

const configuredBaasUrl = import.meta.env.PUBLIC_BAAS_URL ?? '/api';
const baasUrl = configuredBaasUrl.replace(/\/$/, '');
const anonKey = import.meta.env.PUBLIC_BAAS_ANON_KEY ?? '';
---

<Layout title="Confirm newsletter subscription" description="Confirm your Prismatica newsletter double opt-in.">
	<main class="auth-page" data-newsletter-confirm data-baas-url={baasUrl} data-anon-key={anonKey}>
		<section class="auth-card" aria-labelledby="newsletter-confirm-title">
			<p class="eyebrow">Newsletter</p>
			<h1 id="newsletter-confirm-title">Confirming your subscription…</h1>
			<p data-newsletter-confirm-status role="status" aria-live="polite">Checking the confirmation token.</p>
			<a class="text-link" href="/">Return home</a>
		</section>
	</main>
	<script>
		import { createClient } from '@mini-baas/js';

		const root = document.querySelector('[data-newsletter-confirm]') as HTMLElement | null;
		const status = root?.querySelector('[data-newsletter-confirm-status]');
		const token = new URLSearchParams(window.location.search).get('token');
		const baasUrl = root?.dataset.baasUrl?.replace(/\/$/, '') ?? '';
		const anonKey = root?.dataset.anonKey ?? '';
		const setStatus = (message: string, isError = false) => {
			if (!status) return;
			status.textContent = message;
			status.classList.toggle('is-error', isError);
		};
		async function confirmNewsletter() {
			if (!token) {
				setStatus('This newsletter link is missing its token.', true);
				return;
			}
			if (!baasUrl || !anonKey) {
				setStatus('Newsletter confirmation is not configured for this environment.', true);
				return;
			}
			try {
				await createClient({ url: baasUrl, anonKey, persistSession: false }).rpc('gdpr_confirm_newsletter_optin', { token });
			} catch {
				setStatus('This confirmation link is invalid or expired.', true);
				return;
			}
			setStatus('Your newsletter subscription is confirmed. Thank you.');
		}
		void confirmNewsletter().catch(() => setStatus('Could not confirm the newsletter right now. Please try again later.', true));
	</script>
</Layout>
