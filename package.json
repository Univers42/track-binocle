{
  "name": "track-binocle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:all": "docker compose up -d --build --wait",
    "mail": "docker compose up --build mail mail-bridge",
    "mail:down": "docker compose stop mail mail-bridge",
    "mail:logs": "docker compose logs -f mail mail-bridge",
    "calendar": "docker compose up --build calendar calendar-bridge",
    "calendar:down": "docker compose stop calendar calendar-bridge",
    "calendar:logs": "docker compose logs -f calendar calendar-bridge"
  }
}