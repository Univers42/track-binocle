<svg class="visually-hidden" width="0" height="0" aria-hidden="true" focusable="false">
	<defs>
		<filter id="roughen" x="-8%" y="-8%" width="116%" height="116%">
			<feTurbulence type="fractalNoise" baseFrequency="0.025 0.065" numOctaves="3" seed="7" stitchTiles="stitch" result="noise" />
			<feDisplacementMap in="SourceGraphic" in2="noise" scale="1.4" xChannelSelector="R" yChannelSelector="G" />
		</filter>
		<filter id="roughen-light" x="-6%" y="-6%" width="112%" height="112%">
			<feTurbulence type="fractalNoise" baseFrequency="0.022 0.052" numOctaves="2" seed="11" stitchTiles="stitch" result="noise" />
			<feDisplacementMap in="SourceGraphic" in2="noise" scale="0.7" xChannelSelector="R" yChannelSelector="G" />
		</filter>
		<filter id="pencil-texture" x="-8%" y="-8%" width="116%" height="116%">
			<feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="2" seed="19" result="grain" />
			<feBlend in="SourceGraphic" in2="grain" mode="multiply" />
		</filter>
		<pattern id="hatch" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(35)">
			<line x1="0" y1="0" x2="0" y2="8" style="stroke: var(--sketch-line, var(--ink))" stroke-width="0.7" opacity="0.18" />
		</pattern>
		<marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
			<path d="M1 1 L9 5 L1 9" fill="none" style="stroke: var(--ink)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
		</marker>
	</defs>
</svg>
