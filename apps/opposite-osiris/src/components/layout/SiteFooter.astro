---
import { DATA_CONTROLLER, LEGAL_LINKS } from '../../data/legal';
import PrismaticaLogo from '../brand/PrismaticaLogo.astro';

const portalUrl = import.meta.env.PUBLIC_PORTAL_URL ?? 'https://portal.example.com/sign-in';

const socialLinks = [
	{ label: 'GitHub', href: 'https://github.com/Univers42' },
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/' },
	{ label: 'X', href: 'https://x.com/' },
];
---

<footer id="footer" class="site-footer section-shell" role="contentinfo">
	<div class="site-footer__classic" aria-label="Prismatica footer">
		<section class="site-footer__brand" aria-labelledby="footer-brand-title">
			<a class="site-footer__logo" href="/" aria-label="Prismatica home">
				<span aria-hidden="true"><PrismaticaLogo class="site-footer__logo-mark" decorative /></span>
				<strong id="footer-brand-title">Prismatica</strong>
			</a>
			<p>Accessible workspace infrastructure for notes, dashboards, automations and privacy-aware product teams.</p>
		</section>

		<nav class="site-footer__nav" aria-label="Primary footer navigation">
			<h2>Navigate</h2>
			<a href="/">Home</a>
			<a href="/#powers">Features</a>
			<a href="/#baas-status">Pricing</a>
		</nav>

		<section class="site-footer__auth" aria-labelledby="footer-auth-title">
			<h2 id="footer-auth-title">Account</h2>
			<a class="site-footer__signin" href={portalUrl} rel="noopener noreferrer">Sign In <span aria-hidden="true">↗</span></a>
			<form class="site-footer__newsletter" data-newsletter-signup novalidate>
				<label for="footer-newsletter-email">Subscribe for product updates</label>
				<div class="site-footer__newsletter-row">
					<input id="footer-newsletter-email" name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
					<button class="site-footer__subscribe" type="submit" aria-label="Subscribe to product updates">Subscribe</button>
				</div>
				<label class="site-footer__newsletter-consent" for="footer-newsletter-consent">
					<input id="footer-newsletter-consent" name="newsletter_consent" type="checkbox" required />
					<span>Email me occasional updates. I can unsubscribe anytime.</span>
				</label>
				<output class="form-status" role="status" aria-live="polite" data-newsletter-status></output>
			</form>
		</section>

		<section class="site-footer__legal-social" aria-labelledby="footer-legal-title">
			<h2 id="footer-legal-title">Legal & social</h2>
			<nav class="site-footer__legal-links" aria-label="Legal navigation">
				{LEGAL_LINKS.filter((link) => link.label === 'Privacy Policy' || link.label === 'Terms of Service').map((link) => <a href={link.href}>{link.label}</a>)}
				<button class="link-button" type="button" data-manage-cookies aria-label="Open cookie preferences">Cookie preferences</button>
			</nav>
			<nav class="site-footer__social" aria-label="Social links">
				{socialLinks.map((link) => <a href={link.href} rel="noopener noreferrer" aria-label={`${link.label} profile`}>{link.label.slice(0, 2)}</a>)}
			</nav>
			<address class="site-footer__controller">
				<strong>Data controller</strong>
				<span>{DATA_CONTROLLER.name}</span>
				<span>{DATA_CONTROLLER.address}</span>
				<a href={`mailto:${DATA_CONTROLLER.email}`}>{DATA_CONTROLLER.email}</a>
			</address>
		</section>

		<p class="site-footer__legal">© 2026 Prismatica · Predictable navigation, high contrast, keyboard focus states, and no tracking pixels in footer emails.</p>
	</div>
</footer>
