---
import { navItems } from '../../data/site';
import HeaderIcon from '../ui/HeaderIcon.astro';
---

<header class="floating-header" role="banner" aria-label="Primary navigation">
	<a href="#top" class="brand-mark" aria-label="Prismatica home">Prismatica</a>
	<div class="header-mascot-slot" aria-label="Mascot portal launcher">
		<div id="mascot-anchor"></div>
		<span class="header-mascot-note">click to laugh</span>
	</div>
	<nav class="nav-links" aria-label="Sections">
		<ul>
			{navItems.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
		</ul>
	</nav>
	<div class="header-actions">
		<button class="header-cta header-cta--icon" type="button" data-open-portal aria-label="Start workspace" title="Start workspace">
			<HeaderIcon name="start" />
			<span class="visually-hidden">Start workspace</span>
		</button>
		<button class="header-cta header-cta--icon header-cta--connect" type="button" data-open-connect aria-label="Open login" title="Open login">
			<HeaderIcon name="login" />
			<span class="visually-hidden">Open login</span>
		</button>
		<button id="theme-toggle" class="header-cta header-cta--icon header-cta--theme" type="button" aria-label="Theme: light. Switch to dark mode" aria-live="polite" title="Switch theme">
			<span class="header-icon header-icon--theme" aria-hidden="true">☼</span>
			<span class="visually-hidden" data-theme-label>Theme: Light</span>
		</button>
		<button id="pause-animations" class="header-cta header-cta--icon header-cta--motion" type="button" aria-label="Pause animations" aria-pressed="false" title="Pause animations">
			<span class="header-icon header-icon--motion" aria-hidden="true">Ⅱ</span>
			<span class="visually-hidden" data-motion-label>Pause animations</span>
		</button>
	</div>
</header>
