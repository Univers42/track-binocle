{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/adapter-registry/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.build.json"
  },
  "monorepo": true,
  "root": "apps/adapter-registry",
  "projects": {
    "adapter-registry": {
      "type": "application",
      "root": "apps/adapter-registry",
      "entryFile": "main",
      "sourceRoot": "apps/adapter-registry/src",
      "compilerOptions": {
        "tsConfigPath": "apps/adapter-registry/tsconfig.app.json"
      }
    },
    "mongo-api": {
      "type": "application",
      "root": "apps/mongo-api",
      "entryFile": "main",
      "sourceRoot": "apps/mongo-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/mongo-api/tsconfig.app.json"
      }
    },
    "query-router": {
      "type": "application",
      "root": "apps/query-router",
      "entryFile": "main",
      "sourceRoot": "apps/query-router/src",
      "compilerOptions": {
        "tsConfigPath": "apps/query-router/tsconfig.app.json"
      }
    },
    "storage-router": {
      "type": "application",
      "root": "apps/storage-router",
      "entryFile": "main",
      "sourceRoot": "apps/storage-router/src",
      "compilerOptions": {
        "tsConfigPath": "apps/storage-router/tsconfig.app.json"
      }
    },
    "email-service": {
      "type": "application",
      "root": "apps/email-service",
      "entryFile": "main",
      "sourceRoot": "apps/email-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/email-service/tsconfig.app.json"
      }
    },
    "permission-engine": {
      "type": "application",
      "root": "apps/permission-engine",
      "entryFile": "main",
      "sourceRoot": "apps/permission-engine/src",
      "compilerOptions": {
        "tsConfigPath": "apps/permission-engine/tsconfig.app.json"
      }
    },
    "schema-service": {
      "type": "application",
      "root": "apps/schema-service",
      "entryFile": "main",
      "sourceRoot": "apps/schema-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/schema-service/tsconfig.app.json"
      }
    },
    "analytics-service": {
      "type": "application",
      "root": "apps/analytics-service",
      "entryFile": "main",
      "sourceRoot": "apps/analytics-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/analytics-service/tsconfig.app.json"
      }
    },
    "gdpr-service": {
      "type": "application",
      "root": "apps/gdpr-service",
      "entryFile": "main",
      "sourceRoot": "apps/gdpr-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gdpr-service/tsconfig.app.json"
      }
    },
    "newsletter-service": {
      "type": "application",
      "root": "apps/newsletter-service",
      "entryFile": "main",
      "sourceRoot": "apps/newsletter-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/newsletter-service/tsconfig.app.json"
      }
    },
    "ai-service": {
      "type": "application",
      "root": "apps/ai-service",
      "entryFile": "main",
      "sourceRoot": "apps/ai-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ai-service/tsconfig.app.json"
      }
    },
    "log-service": {
      "type": "application",
      "root": "apps/log-service",
      "entryFile": "main",
      "sourceRoot": "apps/log-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/log-service/tsconfig.app.json"
      }
    },
    "session-service": {
      "type": "application",
      "root": "apps/session-service",
      "entryFile": "main",
      "sourceRoot": "apps/session-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/session-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "health": {
      "type": "library",
      "root": "libs/health",
      "entryFile": "index",
      "sourceRoot": "libs/health/src",
      "compilerOptions": {
        "tsConfigPath": "libs/health/tsconfig.lib.json"
      }
    }
  }
}
